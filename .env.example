# Adresse MAC de la machine à réveiller
# Pour votre PC : C8:7F:54:05:E1:09
MAC_ADDRESS=C8:7F:54:05:E1:09

# Adresse IP de diffusion (ou IP publique/DNS pour le réveil à distance via Internet)
# Pour votre configuration actuelle : 176.186.167.152
# (Utilisez 255.255.255.255 si vous êtes sur le même réseau local)
TARGET_IP=176.186.167.152

# Port Wake-on-LAN
# Votre ancien script utilisait le port 7
TARGET_PORT=7
